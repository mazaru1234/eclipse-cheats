# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_SECRET_KEY=your-64-char-hex-key-here
JWT_SECRET=your-jwt-secret-at-least-32-chars

# Local dev: relative path. Production: absolute path, e.g. /var/lib/eclipse-cheats/eclipse.db
DATABASE_URL=./data/eclipse.db

ADMIN_EMAIL=admin@eclipse-cheats.local
ADMIN_PASSWORD=ChangeMe123!

# Platega payments — https://docs.platega.io/
PLATEGA_MERCHANT_ID=your-merchant-uuid
PLATEGA_SECRET=your-api-secret
PLATEGA_USD_RATE=95
NEXT_PUBLIC_PLATEGA_USD_RATE=95

EUR_RUB_RATE=98
NEXT_PUBLIC_EUR_RUB_RATE=98

# Public site URL (required in production)
# Dev:  http://localhost:3000
# Prod: https://eclipse-cheats.ru
NEXT_PUBLIC_APP_URL=http://localhost:3000
