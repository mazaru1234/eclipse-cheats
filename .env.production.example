# Production env for eclipse-cheats.ru
# Copy: cp .env.production.example .env.production

NODE_ENV=production

# Public URL (canonical, with https, without trailing slash)
NEXT_PUBLIC_APP_URL=https://eclipse-cheats.ru

# Secrets — generate new values for production!
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_SECRET_KEY=
JWT_SECRET=

# SQLite path
# Bare metal: /var/lib/eclipse-cheats/eclipse.db
# Docker:     /app/data/eclipse.db
DATABASE_URL=/var/lib/eclipse-cheats/eclipse.db
UPLOADS_DIR=/var/lib/eclipse-cheats/uploads

# First admin (created only if email does not exist)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Platega — https://docs.platega.io/
PLATEGA_MERCHANT_ID=
PLATEGA_SECRET=
PLATEGA_USD_RATE=95
NEXT_PUBLIC_PLATEGA_USD_RATE=95

# Exchange rates
EUR_RUB_RATE=98
NEXT_PUBLIC_EUR_RUB_RATE=98
